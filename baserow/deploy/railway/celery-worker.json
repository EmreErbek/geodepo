{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.railway-backend",
    "dockerTarget": "railway-worker",
    "watchPatterns": [
      "backend/**",
      "Dockerfile.railway-backend",
      "deploy/**"
    ],
    "buildArgs": {
      "SOURCE_REVISION": "celery-worker-fix-3"
    }
  },
  "deploy": {
    "startCommand": "celery-worker",
    "healthcheckPath": null,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}